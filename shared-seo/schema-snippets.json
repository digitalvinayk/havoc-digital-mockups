    "faqPage": {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How long does SEO take to show results?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Realistically: 4–6 months for new sites in low-competition niches, 9–12 months for established sites entering competitive markets, and 12–18 months for national-scale dominance. Any agency promising rankings in 30 days is misleading you."
          }
        },
        {
          "@type": "Question",
          "name": "Do you guarantee specific rankings?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. No legitimate agency does — Google has explicitly stated that ranking guarantees are a red flag. We guarantee process: audits delivered, content shipped, links earned, and monthly reporting on rankings, organic traffic, and revenue attribution."
          }
        },
        {
          "@type": "Question",
          "name": "What does a typical engagement look like?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Discovery call, then a 2–4 week audit phase, then a 90-day priority plan, then monthly delivery cycles with quarterly strategy reviews. We work on rolling 90-day commitments rather than 12-month lock-ins."
          }
        },
        {
          "@type": "Question",
          "name": "How do you report on results?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Weekly Slack updates on activity. Monthly reports covering rankings, traffic, conversions, and revenue attribution where tracking permits. Quarterly business reviews with the principal stakeholder."
          }
        },
        {
          "@type": "Question",
          "name": "How do you choose between SEO, Google Ads, and Social?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The right mix depends on intent, audience, sales cycle, and unit economics. Our default starting recommendation: SEO for compounding long-term value, Google Ads for testable demand at scale, social for retargeting and brand familiarity. We won't push services that don't fit your business."
          }
        },
        {
          "@type": "Question",
          "name": "Why work with a boutique agency instead of a large one?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Large agencies sell senior strategy and deliver junior execution. Boutique agencies like ours deliver senior execution. We have 14 years of accumulated pattern recognition and bring it to every engagement."
          }
        }
      ]
    },
